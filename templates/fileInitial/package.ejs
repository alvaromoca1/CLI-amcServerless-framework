  "main": "handler.js",
  "author": "amc",
  "license": "MIT",
  "scripts": {
    "deploy:dev": "sls deploy --stage dev --region us-east-1",
    "offline": "sls offline --stage dev --region us-east-1 --host 0.0.0.0",
    "test": "jest --verbose --silent ./test/"
  },
  "devDependencies": {
    "@types/jest": "30.4.1",
    "@types/node": "^17.0.45",
    "esbuild": "0.28.1",
    "jest": "30.4.2",
    "jest-junit": "17.0.0",
    "serverless": "4.38.0",
    "serverless-deployment-bucket": "1.6.0",
    "serverless-esbuild": "1.57.2",
    "serverless-iam-roles-per-function": "3.2.0",
    "serverless-import-apigateway": "1.1.1",
    "serverless-middleware": "^3.4.0",
    "serverless-oauth-scopes": "1.0.2",
    "serverless-offline": "14.7.3",
    "serverless-step-functions": "^3.30.0",
    "ts-jest": "29.4.11",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "http-status-codes": "^2.3.0",
    "ajv": "8.20.0",
    "ajv-errors": "3.0.0",
    "ajv-formats": "3.0.1",
    "aws-jwt-verify": "5.2.1",
    "aws-sdk": "2.1693.0",
    "axios": "1.18.0",
    "axios-retry": "^4.5.0",
    "dotenv": "17.4.2",
    "jwt-decode": "^4.0.0",
    "jsonwebtoken": "9.0.3",
    "uuid": "14.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "coverageDirectory": "./coverage/",
    "collectCoverage": true,
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ],
    "moduleNameMapper": {
      "^@application/(.*)$": "<rootDir>/src/application/$1",
      "^@domain/(.*)$": "<rootDir>/src/domain/$1",
      "^@infraestructure/(.*)$": "<rootDir>/src/infraestructure/$1"
    }
  }
